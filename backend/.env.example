# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=kb_user
DB_PASSWORD=YourStrongPassword123!
DB_NAME=knowledge_base

# JWT 密钥（生产环境请修改为随机字符串，至少32位）
JWT_SECRET=your-random-jwt-secret-key-at-least-32-chars

# 服务配置
SERVER_PORT=8080
GIN_MODE=debug

# AI 默认提供商: tongyi / openai / deepseek / zhipu / ollama
AI_DEFAULT_PROVIDER=tongyi

# 通义千问（DashScope）
# 获取 API Key: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=
AI_CHAT_MODEL=qwen-turbo

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  # 自定义端点（可选）

# DeepSeek
# 获取 API Key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 智谱 AI
# 获取 API Key: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-flash

# Ollama（本地模型，不需要 API Key）
# OLLAMA_BASE_URL=http://localhost:11434/api/chat
# OLLAMA_MODEL=llama3

# 嵌入模型（目前仅支持通义千问）
AI_EMBEDDING_MODEL=text-embedding-v3

# Meilisearch 全文搜索
# 下载: https://www.meilisearch.com/downloads
# 启动: meilisearch --config-file-path=./meilisearch.toml
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=
MEILISEARCH_INDEX=documents
